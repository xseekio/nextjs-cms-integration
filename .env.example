# xSeek API base URL
XSEEK_API_URL=https://www.xseek.io

# API key with `articles:read` privilege
XSEEK_API_KEY=

# Website ID — find in your xSeek dashboard URL: /dashboard/websites/<id>
XSEEK_WEBSITE_ID=

# Shared secret for the on-demand revalidate webhook
XSEEK_REVALIDATE_SECRET=

# Public site URL — used to build absolute URLs in the sitemap.
# Defaults to http://localhost:3000 when unset.
SITE_URL=https://yourdomain.com
